# NOOSPHERE v2 — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.
# GitHub Actions: set these as repository secrets.

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://isfhndnwydnqbmvixddm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Anthropic ────────────────────────────────────────────────────────────────
# Used by Jarvis, Vanguard, Skeptic, Advocate, and Adversarial agents
# Default model: claude-sonnet (NOT opus — cost control)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Daemon Configuration ─────────────────────────────────────────────────────
# Number of claims to process per pipeline cycle
DAEMON_BATCH_SIZE=20

# Trust threshold for Tier 2 → Tier 3 promotion evaluation
DAEMON_PROMOTION_THRESHOLD=0.90

# Fraction of Tier 2 promotions to flag for human audit
DAEMON_AUDIT_SAMPLE_RATE=0.10

# ── Alerting (optional) ──────────────────────────────────────────────────────
# Webhook URL for alert notifications (Slack, Discord, etc.)
# If not set, alerts are logged but not pushed.
# Triggered by: DEMOTION, FAILURE_CLUSTER, COST_ALERT, TRUST_WARNING, TIER3_ELIGIBLE
WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Edge Function Endpoints (read-only reference) ────────────────────────────
# Live Cosmos Map API (no auth required, 5-min cache)
# COSMOS_MAP_URL=https://isfhndnwydnqbmvixddm.supabase.co/functions/v1/serve-cosmos-map
# COSMOS_MAP_URL=https://isfhndnwydnqbmvixddm.supabase.co/functions/v1/serve-cosmos-map?domain=finance

# Alert webhook trigger (no auth required)
# SEND_ALERTS_URL=https://isfhndnwydnqbmvixddm.supabase.co/functions/v1/send-alerts
